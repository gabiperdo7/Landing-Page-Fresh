# CAMBIAR AQUÍ: puerto del backend
PORT=4000

# CAMBIAR AQUÍ: URL de PostgreSQL (usuario, password, host, puerto, base)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/personal_trainer_app

# CAMBIAR AQUÍ: secreto JWT fuerte y largo
JWT_SECRET=CAMBIAR_ESTE_SECRETO_SUPER_LARGO

# CAMBIAR AQUÍ: tiempo de expiración del token (ej: 2h)
JWT_EXPIRES_IN=2h

# CAMBIAR AQUÍ: entorno de ejecución (development o production)
NODE_ENV=development

# CAMBIAR AQUÍ: dominio permitido del frontend
FRONTEND_ORIGIN=http://localhost:3000

# CAMBIAR AQUÍ: credenciales del admin inicial
ADMIN_USERNAME=admin_master
ADMIN_EMAIL=admin@cambiar.com
ADMIN_PASSWORD=Admin12345!
ADMIN_NOMBRE=Admin
ADMIN_APELLIDO=Principal
ADMIN_TELEFONO=111111111
